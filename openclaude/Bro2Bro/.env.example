# ============================================
# Bro2Bro Environment Configuration
# Copy this file to .env.local for local development
# Or set these variables in your hosting platform (Render, Vercel, etc.)
# ============================================

# REQUIRED: Database
# For local development with Docker:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/bro2bro?schema=public"
# For Render PostgreSQL (replace with your actual values):
DATABASE_URL="postgresql://username:password@host:5432/bro2bro?schema=public"

# REQUIRED: NextAuth.js Configuration
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
# For production: NEXTAUTH_URL="https://your-app.onrender.com"

# OPTIONAL: Google OAuth (Required for Google login)
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OPTIONAL: Socket.io (default: same as NEXTAUTH_URL)
# For local development:
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
# For production, this will be same as your domain

# OPTIONAL: AWS S3 (for avatar uploads)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# OPTIONAL: Redis (for production rate limiting)
# If not set, uses in-memory rate limiting (fine for small apps)
REDIS_URL=""

# OPTIONAL: Google Gemini (for Bro Bot AI features)
# Get free API key from: https://ai.google.dev
GEMINI_API_KEY=""

# App Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Bro2Bro"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate Limiting (per hour/minute)
RATE_LIMIT_BRO_SEND=30
RATE_LIMIT_REACTION=100
RATE_LIMIT_FEED_REQUEST=60

# Feature Flags
ENABLE_ANONYMOUS_BROS=true
ENABLE_LOCATION_FEATURES=true
ENABLE_AI_BOT=false
ENABLE_ADULT_FILTER=true
