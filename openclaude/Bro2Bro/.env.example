# Database
DATABASE_URL="postgresql://username:password@localhost:5432/bro2bro?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Socket.io
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
SOCKET_PORT=3001

# AWS S3 (for avatars/media)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# Redis (for rate limiting & caching)
REDIS_URL="redis://localhost:6379"

# OpenAI (for Bro Bot)
OPENAI_API_KEY=""

# App Config
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Bro2Bro"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_BRO_SEND=30      # Per hour
RATE_LIMIT_REACTION=100     # Per hour
RATE_LIMIT_FEED_REQUEST=60  # Per minute

# Feature Flags
ENABLE_ANONYMOUS_BROS=true
ENABLE_LOCATION_FEATURES=true
ENABLE_AI_BOT=false
ENABLE_ADULT_FILTER=true
