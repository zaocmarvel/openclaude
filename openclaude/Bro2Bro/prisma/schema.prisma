// Bro2Bro Database Schema
// Production-ready PostgreSQL schema with full feature support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  displayName   String?
  handle        String    @unique
  password      String?
  bio           String?
  image         String?
  banner        String?
  isVerified         Boolean   @default(false)
  isPrivate          Boolean   @default(false)
  emailVerified      DateTime?
  onboardingCompleted Boolean   @default(false)
  lastActiveAt  DateTime  @default(now())
  latitude     Float?
  longitude    Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  comments      Comment[]
  reactions     Reaction[]

  // Friend/Follow relations
  followers     Follow[] @relation("UserFollowers")
  following     Follow[] @relation("UserFollowing")

  // Chat relations
  chatMembers   ChatMember[]
  messages      Message[]

  // Notifications
  notifications Notification[] @relation("UserNotifications")
  triggeredNotifications Notification[] @relation("NotificationTrigger")

  // Blocked users
  blocked       Block[] @relation("UserBlocked")
  blockedBy     Block[] @relation("UserBlockedBy")

  // Personality profile
  personalityProfile PersonalityProfile?

  // Streaks
  streakUser1 Streak[] @relation("StreakUser1")
  streakUser2 Streak[] @relation("StreakUser2")

  // Bro relations (sender/receiver)
  sentBros     Bro[] @relation("BroSender")
  receivedBros Bro[] @relation("BroReceiver")

  // Interaction logs
  interactionLogs InteractionLog[] @relation("UserInteractions")

  // Reports filed by user
  reportsFiled Report[] @relation("ReportFiler")
  reportsAgainstUser Report[] @relation("ReportTarget")

  // Safety flags
  safetyFlags SafetyFlag[]

  // Guess attempts
  guessAttempts GuessAttempt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// SOCIAL FEATURES
// ============================================

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  status      FollowStatus @default(PENDING)
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId, status])
}

enum FollowStatus {
  PENDING   // For private accounts
  ACCEPTED  // Follow confirmed
}

model Block {
  id          String   @id @default(cuid())
  issuerId    String
  receiverId  String
  createdAt   DateTime @default(now())

  issuer   User @relation("UserBlocked", fields: [issuerId], references: [id], onDelete: Cascade)
  receiver User @relation("UserBlockedBy", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([issuerId, receiverId])
}

// ============================================
// BRO MODEL (Core feature)
// ============================================

model Bro {
  id              String        @id @default(cuid())
  senderId        String
  receiverId      String
  type            BroType
  message         String?       @db.Text
  isAnonymous     Boolean       @default(false)
  revealedAt      DateTime?
  status          BroStatus     @default(PENDING)
  viewedAt        DateTime?
  reactionCount   Int           @default(0)
  engagementScore Int           @default(0)
  isDeleted       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  sender          User          @relation("BroSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        User          @relation("BroReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  reactions       Reaction[]
  comments        Comment[]
  guessAttempts   GuessAttempt[]
  reports         Report[]

  // Analytics
  stats           BroStats?

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([receiverId, status])
  @@index([type])
}

enum BroStatus {
  PENDING
  VIEWED
  REVEALED
  EXPIRED
}

model BroStats {
  id              String   @id @default(cuid())
  broId           String   @unique
  views           Int      @default(0)
  uniqueViews     Int      @default(0)
  impressions     Int      @default(0)
  shares          Int      @default(0)
  bookmarks       Int      @default(0)

  bro Bro @relation(fields: [broId], references: [id], onDelete: Cascade)
}

// ============================================
// CONTENT MODELS (Posts for feed)
// ============================================

model Post {
  id          String    @id @default(cuid())
  content     String    @db.Text
  authorId    String
  parentId    String?   // For replies
  replyToId   String?   // For replies to specific post
  mediaCount  Int       @default(0)
  isDeleted   Boolean   @default(false)
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent      Post?      @relation("PostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Post[]     @relation("PostReplies")
  replyTo     Post?      @relation("PostReplyTo", fields: [replyToId], references: [id], onDelete: Cascade)
  replyFrom   Post[]     @relation("PostReplyTo")
  media       Media[]
  reactions   Reaction[]
  comments    Comment[]
  reports     Report[]

  // Analytics (denormalized for performance)
  stats       PostStats?

  @@index([authorId, createdAt])
  @@index([parentId])
  @@index([createdAt])
}

model Media {
  id        String     @id @default(cuid())
  postId    String
  commentId String?
  type      MediaType
  url       String
  thumbnail String?    // For videos
  width     Int?
  height    Int?
  size      Int?       // File size in bytes
  duration  Float?     // For videos (seconds)
  order     Int        @default(0)
  createdAt DateTime   @default(now())

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([postId, order])
}

enum MediaType {
  IMAGE
  VIDEO
  GIF
}

model PostStats {
  id           String @id @default(cuid())
  postId       String @unique
  views        Int    @default(0)
  uniqueViews  Int    @default(0)
  impressions  Int    @default(0)
  shares       Int    @default(0)
  bookmarks    Int    @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ============================================
// ENGAGEMENT MODELS
// ============================================

model Reaction {
  id        String       @id @default(cuid())
  type      ReactionType
  userId    String
  postId    String?
  broId     String?
  commentId String?
  createdAt DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  bro     Bro?     @relation(fields: [broId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
  @@unique([userId, broId, type])
  @@unique([userId, commentId, type])
  @@index([postId, type])
  @@index([broId, type])
  @@index([commentId, type])
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

model Comment {
  id         String    @id @default(cuid())
  content    String    @db.Text
  authorId   String
  postId     String?
  broId      String?
  parentId   String?   // For nested replies
  mediaCount Int       @default(0)
  isDeleted  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  bro       Bro?       @relation(fields: [broId], references: [id], onDelete: Cascade)
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")
  reactions Reaction[]
  media     Media[]

  @@index([postId, createdAt])
  @@index([broId, createdAt])
  @@index([parentId])
}

// ============================================
// CHAT/Messaging
// ============================================

model Chat {
  id          String      @id @default(cuid())
  name        String?
  avatar      String?
  isGroup     Boolean     @default(false)
  createdBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  members     ChatMember[]
  messages    Message[]

  @@index([updatedAt])
}

model ChatMember {
  id          String    @id @default(cuid())
  chatId      String
  userId      String
  role        ChatRole  @default(MEMBER)
  isMuted     Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  lastReadAt  DateTime  @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId, lastReadAt])
}

enum ChatRole {
  MEMBER
  ADMIN
  OWNER
}

model Message {
  id          String        @id @default(cuid())
  chatId      String
  senderId    String
  content     String?       @db.Text
  type        MessageType   @default(TEXT)
  mediaUrl    String?
  replyToId   String?
  isEdited    Boolean       @default(false)
  isDeleted   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  chat        Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo     Message?      @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: Cascade)
  replies     Message[]     @relation("MessageReplies")
  readBy      MessageRead[]

  @@index([chatId, createdAt])
  @@index([senderId])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  SYSTEM
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  userId      String           // Recipient
  triggeredBy String           // Who triggered
  postId      String?
  commentId   String?
  messageId   String?
  metadata    String?          @db.Text // JSON for extra data
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user        User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  trigger     User @relation("NotificationTrigger", fields: [triggeredBy], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([triggeredBy])
}

enum NotificationType {
  FOLLOW
  FOLLOW_REQUEST
  POST_LIKE
  POST_COMMENT
  COMMENT_REPLY
  MENTION
  REPOST
  MESSAGE
  GROUP_INVITE
}

// ============================================
// FEATURED & DISCOVERY
// ============================================

model Trending {
  id          String   @id @default(cuid())
  hashtag     String   @unique
  postCount   Int      @default(0)
  score       Float    @default(0)
  updatedAt   DateTime @updatedAt

  @@index([score])
}

model FeaturedUser {
  id        String   @id @default(cuid())
  userId    String   @unique
  reason    String?
  priority  Int      @default(0)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([priority, createdAt])
}

// ============================================
// PERSONALITY PROFILE
// ============================================

model PersonalityProfile {
  id                    String     @id @default(cuid())
  userId                String     @unique
  preferredBroType      BroType?
  aggressiveCount       Int        @default(0)
  funnyCount            Int        @default(0)
  coldCount             Int        @default(0)
  heartbreakCount       Int        @default(0)
  respectCount          Int        @default(0)
  totalResponses        Int        @default(0)
  avgResponseTimeMinutes Int?
  engagementRate        Float      @default(0)
  updatedAt             DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BroType {
  AGGRESSIVE
  FUNNY
  COLD
  HEARTBREAK
  RESPECT
}

// ============================================
// STREAK
// ============================================

model Streak {
  id         String   @id @default(cuid())
  user1Id    String
  user2Id    String
  count      Int      @default(0)
  bestCount  Int      @default(0)
  lastBroAt  DateTime
  expiresAt  DateTime
  totalBros  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user1 User @relation("StreakUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("StreakUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
}

// ============================================
// GUESS ATTEMPTS (for anonymous bros)
// ============================================

model GuessAttempt {
  id        String   @id @default(cuid())
  broId     String
  userId    String
  guessedId String
  isCorrect Boolean
  createdAt DateTime @default(now())

  bro     Bro  @relation(fields: [broId], references: [id], onDelete: Cascade)
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([broId])
  @@index([userId])
}

// ============================================
// REPORTS (Moderation)
// ============================================

model Report {
  id          String        @id @default(cuid())
  reporterId  String
  targetType  ReportTargetType
  targetId    String
  broId       String?
  postId      String?
  userId      String?
  reason      String
  description String?       @db.Text
  status      ReportStatus  @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  reporter User  @relation("ReportFiler", fields: [reporterId], references: [id], onDelete: Cascade)
  bro      Bro?  @relation(fields: [broId], references: [id], onDelete: Cascade)
  post     Post? @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User? @relation("ReportTarget", fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([broId])
  @@index([postId])
  @@index([userId])
}

enum ReportTargetType {
  BRO
  POST
  USER
  COMMENT
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

// ============================================
// SAFETY FLAGS
// ============================================

model SafetyFlag {
  id          String       @id @default(cuid())
  userId      String
  type        SafetyFlagType
  severity    Int          @default(1) // 1-5
  description String?      @db.Text
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  expiresAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

enum SafetyFlagType {
  RATE_LIMIT
  SUSPICIOUS_ACTIVITY
  ABUSE
  SPAM
}

// ============================================
// INTERACTION LOGS
// ============================================

model InteractionLog {
  id          String   @id @default(cuid())
  userId      String
  targetId    String
  targetType  String   // BRO, POST, USER, etc.
  action      String   // VIEW, REACT, COMMENT, etc.
  metadata    String?  @db.Text // JSON
  createdAt   DateTime @default(now())

  user User @relation("UserInteractions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([targetId, targetType])
}
